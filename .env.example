# ─── Server ───────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────
# Replace with your Atlas connection string
MONGO_URI=

# ─── JWT ──────────────────────────────────────
# Use a long, random string in production
JWT_SECRET=

# ─── CORS ─────────────────────────────────────
# Frontend URL (used in production for CORS whitelist)
FRONTEND_URL=http://localhost:5173

# ─── Test Database (optional) ─────────────────
# Separate Atlas database used only during `npm test`
# Falls back to MONGO_URI if not set
MONGO_URI_TEST=
